# Copia a .env local (no subir secretos). En Vercel: Project → Settings → Environment Variables.
# Nombres exactos que usa el proyecto:

# Cliente (también devueltos por GET /api/supabase-config para el HTML estático)
PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Mismo proyecto en Hecom y en marketing = mismo "servidor de auth" y mismos usuarios.
# Eso NO copia la sesión entre dominios: el token queda en localStorage (u otro storage) POR ORIGEN.
# www.hecom.club y www.marketingconholistic.com son orígenes distintos → cada uno tiene su copia o vacío.
# Por eso hace falta pasar tokens en el hash al abrir panel, o volver a magic link en cada sitio/navegador.
# No expongas SERVICE_ROLE ni DATABASE al front: nunca prefijos tipo NEXT_PUBLIC_/VITE_ con secretos.

# Opcional: URL completa del Edge Function magic-link-login si no está en el mismo proyecto
# PUBLIC_MAGIC_LINK_LOGIN_URL=https://xxxxxxxx.supabase.co/functions/v1/magic-link-login

# Solo servidor (funciones / scripts admin). No usar en el navegador.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Conexión Postgres (Prisma, Drizzle, migraciones locales). Copiar desde Supabase → Project Settings → Database.
# URL con pooler (p. ej. :6543 / transaction) y DIRECT_URL sin pooler para migraciones.
DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres
