{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/credito", "destination": "https://www.marketingconholistic.com/credito" },
    { "source": "/credito.html", "destination": "https://www.marketingconholistic.com/credito.html" },
    { "source": "/credito-app/:path*", "destination": "https://www.marketingconholistic.com/credito-app/:path*" },
    { "source": "/pendientes", "destination": "https://www.marketingconholistic.com/pendientes" },
    { "source": "/pendientes/:path*", "destination": "https://www.marketingconholistic.com/pendientes/:path*" },
    { "source": "/creativos", "destination": "https://www.marketingconholistic.com/creativos" },
    { "source": "/creativos/:path*", "destination": "https://www.marketingconholistic.com/creativos/:path*" },
    { "source": "/finanzas", "destination": "https://www.marketingconholistic.com/finanzas" },
    { "source": "/finanzas/:path*", "destination": "https://www.marketingconholistic.com/finanzas/:path*" },
    { "source": "/acceso-creativos", "destination": "https://www.marketingconholistic.com/acceso-creativos" },
    { "source": "/acceso-creativos.html", "destination": "https://www.marketingconholistic.com/acceso-creativos.html" },
    { "source": "/acceso-pendientes", "destination": "https://www.marketingconholistic.com/acceso-pendientes" },
    { "source": "/acceso-pendientes.html", "destination": "https://www.marketingconholistic.com/acceso-pendientes.html" },
    { "source": "/acceso-finanzas", "destination": "https://www.marketingconholistic.com/acceso-finanzas" },
    { "source": "/acceso-finanzas.html", "destination": "https://www.marketingconholistic.com/acceso-finanzas.html" },
    { "source": "/acceso-tareas", "destination": "https://www.marketingconholistic.com/acceso-tareas" },
    { "source": "/tareas", "destination": "https://www.marketingconholistic.com/tareas" },
    { "source": "/tareas/:path*", "destination": "https://www.marketingconholistic.com/tareas/:path*" },
    { "source": "/api/cobranzaClaudeSuggest", "destination": "https://www.marketingconholistic.com/api/cobranzaClaudeSuggest" },
    { "source": "/borrador-correo-formal", "destination": "https://www.marketingconholistic.com/borrador-correo-formal" },
    { "source": "/borrador-correo-formal.html", "destination": "https://www.marketingconholistic.com/borrador-correo-formal.html" },
    { "source": "/backup-dashboard", "destination": "https://www.marketingconholistic.com/backup-dashboard" },
    { "source": "/backup-dashboard/:path*", "destination": "https://www.marketingconholistic.com/backup-dashboard/:path*" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/destinos",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/login",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/forgot-password",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/auth/reset-password",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
